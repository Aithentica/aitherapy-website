---
import type { Locale } from '../../i18n/config';
import { defaultLocale } from '../../i18n/config';
import { getNavigation } from '../../data/navigation';

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const navItems = getNavigation(locale);
---

<nav class="flex items-center gap-1" aria-label="Main navigation">
  {navItems.map((item) => {
    return (
      <a
        href={item.href}
        class="px-3 py-2 text-sm font-medium text-brand-100 hover:text-white rounded-lg transition-colors"
        {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
      >
        {item.label}
      </a>
    );
  })}
</nav>
