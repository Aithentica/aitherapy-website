---
import type { Locale } from '../../i18n/config';
import { defaultLocale } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';

interface Props {
  locale?: Locale;
}

interface TrustLogo {
  src: string;
  alt: string;
}

const { locale = defaultLocale } = Astro.props;
const t = useTranslations(locale);

const logos: TrustLogo[] = [
  { src: '/images/trust/unicorn-hub.png', alt: 'Unicorn Hub' },
  { src: '/images/trust/partner-1.png', alt: 'Sanitas Centrum Medyczne' },
  { src: '/images/logos/microsoft-for-startups.png', alt: 'Microsoft for Startups' },
  { src: '/images/trust/partner-2.png', alt: 'Lubelska Medycyna' },
  { src: '/images/trust/swps-startup-booster.png', alt: 'Startup Booster for Social Impact – SWPS University' },
  { src: '/images/trust/pan.png', alt: 'Polska Akademia Nauk' },
  { src: '/images/trust/experimental-psychopathology-lab.png', alt: 'Experimental Psychopathology Lab – Institute of Psychology, Polish Academy of Sciences' },
];
---

<section class="py-12 lg:py-16 bg-white border-b border-slate-100 overflow-hidden">
  <p class="text-center text-slate-400 text-xs font-semibold uppercase tracking-[3px] mb-8">
    {t.trustLogos.title}
  </p>

  <div class="logo-marquee">
    <div class="logo-track">
      {logos.map((logo) => (
        <img
          src={logo.src}
          alt={logo.alt}
          class="h-10 lg:h-14 w-auto max-w-[160px] lg:max-w-[200px] object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300 flex-shrink-0"
          loading="lazy"
        />
      ))}
      {logos.map((logo) => (
        <img
          src={logo.src}
          alt={logo.alt}
          class="h-10 lg:h-14 w-auto max-w-[160px] lg:max-w-[200px] object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300 flex-shrink-0"
          aria-hidden="true"
          loading="lazy"
        />
      ))}
    </div>
  </div>
</section>

<style>
  .logo-marquee {
    --gap: 3rem;
    mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
  }

  .logo-track {
    display: flex;
    align-items: center;
    gap: var(--gap);
    width: max-content;
    animation: scroll 30s linear infinite;
  }

  .logo-track:hover {
    animation-play-state: paused;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-50% - var(--gap) / 2));
    }
  }
</style>
