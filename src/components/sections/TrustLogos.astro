---
interface TrustLogo {
  src: string;
  alt: string;
}

const logos: TrustLogo[] = [
  { src: '/images/trust/unicorn-hub.png', alt: 'Unicorn Hub' },
  { src: '/images/trust/partner-1.png', alt: 'Sanitas Centrum Medyczne' },
  { src: '/images/logos/microsoft-for-startups.png', alt: 'Microsoft for Startups' },
  { src: '/images/trust/partner-2.png', alt: 'Lubelska Medycyna' },
  { src: '/images/trust/swps-startup-booster.png', alt: 'Startup Booster for Social Impact – SWPS University' },
  { src: '/images/trust/pan.png', alt: 'Polska Akademia Nauk' },
  { src: '/images/trust/experimental-psychopathology-lab.png', alt: 'Experimental Psychopathology Lab – Institute of Psychology, Polish Academy of Sciences' },
];
---

<section class="py-12 lg:py-16 bg-white border-b border-slate-100">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-center text-slate-400 text-xs font-semibold uppercase tracking-[3px] mb-8">
      Zaufali nam
    </p>

    <div class="flex flex-wrap justify-center items-center gap-8 lg:gap-12">
      {logos.map((logo) => (
        <img
          src={logo.src}
          alt={logo.alt}
          class="h-10 lg:h-14 w-auto max-w-[160px] lg:max-w-[200px] object-contain grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
          loading="lazy"
        />
      ))}
    </div>
  </div>
</section>
