---
import type { Locale } from '../i18n/config';
import { locales, localeNames, defaultLocale } from '../i18n/config';

interface Props {
  locale: Locale;
  /** Current path without locale prefix, e.g. '/features/' */
  currentPath?: string;
}

const { locale, currentPath = '/' } = Astro.props;

function buildUrl(targetLocale: Locale): string {
  if (targetLocale === defaultLocale) return currentPath;
  return `/${targetLocale}${currentPath}`;
}

// Short display codes
const shortNames: Record<Locale, string> = {
  en: 'EN',
  pl: 'PL',
  sk: 'SK',
  ca: 'CA',
  ru: 'RU',
  uk: 'UK',
  lt: 'LT',
};
---

<div class="relative" data-lang-switcher>
  <button
    type="button"
    class="flex items-center gap-1 px-2.5 py-1.5 rounded-lg text-xs font-semibold text-brand-100 hover:text-white hover:bg-white/10 transition-colors"
    aria-label="Change language"
    data-lang-toggle
  >
    {shortNames[locale]}
    <svg class="w-3 h-3 opacity-60" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </button>
  <div
    class="hidden absolute right-0 top-full mt-1 bg-white rounded-lg shadow-lg border border-gray-100 py-1 min-w-[140px] z-50"
    data-lang-dropdown
  >
    {locales.map((l) => (
      <a
        href={buildUrl(l)}
        class:list={[
          'flex items-center gap-2 px-3 py-2 text-sm transition-colors',
          l === locale
            ? 'bg-brand-50 text-brand-500 font-semibold'
            : 'text-gray-700 hover:bg-gray-50',
        ]}
      >
        <span class="font-mono text-xs w-5">{shortNames[l]}</span>
        <span>{localeNames[l]}</span>
      </a>
    ))}
  </div>
</div>

<script is:inline>
  if (!window.__langSwitcherInit) {
    window.__langSwitcherInit = true;
    document.querySelectorAll('[data-lang-switcher]').forEach(function(switcher) {
      var toggle = switcher.querySelector('[data-lang-toggle]');
      var dropdown = switcher.querySelector('[data-lang-dropdown]');
      toggle.addEventListener('click', function(e) {
        e.stopPropagation();
        dropdown.classList.toggle('hidden');
      });
    });
    document.addEventListener('click', function() {
      document.querySelectorAll('[data-lang-dropdown]').forEach(function(d) {
        d.classList.add('hidden');
      });
    });
  }
</script>
