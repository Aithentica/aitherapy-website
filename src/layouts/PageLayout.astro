---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  schema?: Record<string, unknown>;
  noindex?: boolean;
}

const { title, description, ogImage, canonicalURL, schema, noindex } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  canonicalURL={canonicalURL}
  schema={schema}
  noindex={noindex}
>
  <Header />
  <main>
    <slot />
  </main>

  <!-- ===== CTA — dark teal cover ===== -->
  <section class="ts-cover ts-cover-sm relative overflow-hidden bg-brand-500 py-20 lg:py-28">
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-accent-400 text-xs font-bold tracking-[4px] uppercase mb-6">
        Beta testy · Dołącz teraz
      </p>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6">
        Odzyskaj czas dla siebie<br />i swoich <em class="not-italic text-accent-400">pacjentów</em>
      </h2>
      <p class="text-white/65 text-lg leading-relaxed mb-10 max-w-xl mx-auto">
        Jesteś terapeutą / terapeutką CBT?
        Sprawdź, jak platforma wspiera Twoją codzienną pracę.
        Podsumowania sesji, które porządkują materiał kliniczny.
        Administracja, która nie przeszkadza.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/betatester/"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-accent-400 text-brand-500 font-bold text-base hover:bg-accent-300 transition-colors shadow-lg">
          Zgłoś się do beta testów
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
