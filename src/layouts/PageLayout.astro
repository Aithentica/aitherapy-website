---
import type { Locale } from '../i18n/config';
import { defaultLocale } from '../i18n/config';
import { useTranslations, localizedUrl } from '../i18n/utils';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  schema?: Record<string, unknown>;
  noindex?: boolean;
  locale?: Locale;
}

const { title, description, ogImage, canonicalURL, schema, noindex, locale = defaultLocale } = Astro.props;
const t = useTranslations(locale);
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  canonicalURL={canonicalURL}
  schema={schema}
  noindex={noindex}
  locale={locale}
>
  <Header locale={locale} />
  <main>
    <slot />
  </main>

  <!-- ===== CTA — dark teal cover ===== -->
  <section class="ts-cover ts-cover-sm relative overflow-hidden bg-brand-500 py-20 lg:py-28">
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-accent-400 text-xs font-bold tracking-[4px] uppercase mb-6">
        {t.pageCta.subtitle}
      </p>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6">
        {t.pageCta.title1}<br />{t.pageCta.title2} <em class="not-italic text-accent-400">{t.pageCta.titleAccent}</em>
      </h2>
      <p class="text-white/65 text-lg leading-relaxed mb-10 max-w-xl mx-auto">
        {t.pageCta.desc1}<br />
        <strong>{t.pageCta.desc2}</strong><br />
        {t.pageCta.desc3}
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={localizedUrl('/betatester/', locale)}
          class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-accent-400 text-brand-500 font-bold text-base hover:bg-accent-300 transition-colors shadow-lg">
          {t.pageCta.button}
        </a>
      </div>
    </div>
  </section>

  <Footer locale={locale} />
</BaseLayout>
