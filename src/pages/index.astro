  }

  /* Feature block */
  .ts-feature-block {
    background: white;
    border-radius: 20px;
    border: 1px solid #E2E8F0;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.04);
    overflow: hidden;
  }
  .ts-feature-header {
    padding: 28px 32px;
    border-bottom: 1px solid #E2E8F0;
  }
  .ts-feature-body {
    padding: 24px 32px;
  }

  /* DM Mono badge */
  .ts-feature-badge {
    display: inline-flex;
    align-items: center;
