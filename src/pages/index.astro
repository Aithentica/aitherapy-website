---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { testimonials } from '../data/testimonials';
import { faqItems } from '../data/faq';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const features = [
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3Z" /></svg>`,
    title: 'Inteligentna notatka',
    desc: 'Więcej niż transkrypcja. AI rozróżnia mówców, wychwytuje interwencje i tworzy ustrukturowaną notatkę kliniczną (SOAP/BIRP) w mniej niż 30 sekund',
    points: ['Rozróżnianie mówców w czasie rzeczywistym', 'Wykrywanie interwencji i kluczowych treści klinicznych', 'Notatka gotowa w mniej niż 30 sekund', 'Podgląd i edycja po sesji'],
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 14.25v2.25m3-4.5v4.5m3-6.75v6.75m3-9v9M6 20.25h12A2.25 2.25 0 0 0 20.25 18V6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v12A2.25 2.25 0 0 0 6 20.25Z" /></svg>`,
    title: 'Konceptualizacja',
    desc: 'Generowanie diagramów kognitywnych, modeli błędnego koła, map problemów i analiz ABC<br />- jednym kliknięciem',
    points: ['Diagram kognitywny CBT generowany z treści sesji', 'Model błędnego koła i analiza ABC jednym kliknięciem', 'Eksport do PDF', 'Aktualizacja diagramu wraz z kolejnymi sesjami'],
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5m.75-9 3-3 2.148 2.148A12.061 12.061 0 0 1 16.5 7.605" /></svg>`,
    title: 'Zestawienia',
    desc: 'Porównanie notatek między sesjami i śledzenie wyników kwestionariuszy - cały przebieg terapii na jednym ekranie',
    points: ['Porównanie notatek między sesjami', 'Śledzenie wyników kwestionariuszy', 'Wizualizacja postępu terapii', 'Uporządkowane podsumowanie przebiegu terapii'],
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>`,
    title: 'Bezpieczeństwo na każdym etapie',
    desc: 'Szyfrowanie end-to-end, lokalna anonimizacja danych, pełna zgodność z RODO i AI Act',
    points: ['Szyfrowanie end-to-end', 'Anonimizacja lokalna przed transmisją', 'Pełna zgodność z RODO i AI Act', 'Dane kliniczne są dostępne wyłącznie dla Ciebie'],
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" /></svg>`,
    title: 'Współpraca z superwizorem',
    desc: 'Materiały gotowe do omówienia - bez dodatkowego opracowywania i bez przeciążenia materiałem',
    points: ['Materiały do superwizji bez dodatkowej pracy', 'Chronologiczny podgląd przebiegu terapii w jednym miejscu', 'Wyodrębnione kluczowe wątki, hipotezy i momenty zmiany', 'Automatycznie uporządkowany materiał gotowy do superwizji'],
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>`,
    title: 'Zarządzanie gabinetem',
    desc: 'Spokojne prowadzenie gabinetu – mniej zadań między sesjami',
    points: ['Kalendarz, który pomaga utrzymać uporządkowany grafik i stałe obłożenie', 'Automatyczne przypomnienia SMS ograniczające odwołania wizyt', 'Płatności w jednym miejscu, bez przełączania się między systemami', 'Narzędzia wspierające świadome planowanie pracy'],
  },
];
---

<BaseLayout
  title="Therapy Support"
  description="Zintegrowana Platforma dla Terapeutów CBT. Nowy standard w psychoterapii."
>

  <!-- ===== HEADER ===== -->
  <Header />

  <main style="background: #F0F4F3;">

    <!-- ===== HERO — dark teal cover ===== -->
    <section class="ts-cover relative overflow-hidden bg-brand-500">
      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

          <!-- Left: text -->
          <div>
            <p class="text-accent-400 text-xs font-bold tracking-[4px] uppercase mb-10">
              Therapy Support · Platforma dla Terapeutów CBT
            </p>
            <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight text-white mb-6">
              Platforma dla<br />Terapeutów <em class="not-italic text-accent-400">CBT</em>
            </h1>
            <p class="text-white/65 text-lg leading-relaxed mb-10 max-w-lg">
              Od wstępnej konsultacji i wywiadu, przez konceptualizację i plan terapii,
              aż po notatki z sesji - całość w jednym, bezpiecznym miejscu
              z odpowiedzialnym wsparciem AI.
              <br /><br />Jasny obraz pacjenta, pewniejsze decyzje kliniczne.
              <br />Mniej dokumentacji, więcej czasu na terapię.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 mb-14">
              <a href="https://app.aitherapy.support/betatester" target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-accent-400 text-brand-500 font-bold text-sm hover:bg-accent-300 transition-colors shadow-lg">
                Zgłoś się do beta testów
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </a>
              <a href="/funkcjonalnosci/"
                class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-white/10 border border-white/20 text-white font-semibold text-sm hover:bg-white/15 transition-colors">
                Poznaj funkcjonalności
              </a>
            </div>
            <!-- Stat chips -->
            <div class="flex flex-wrap gap-3">
              {[
                { num: '10-15h', label: 'oszczędności miesięcznie' },
                { num: '30s', label: 'notatka z sesji' },
                { num: 'RODO', label: '100% zgodność' },
              ].map((s) => (
                <div class="ts-chip">
                  <strong>{s.num}</strong>{s.label}
                </div>
              ))}
            </div>
          </div>

          <!-- Right: SVG device mockup -->
          <div class="relative mx-auto lg:mx-0 max-w-lg w-full">
            <svg viewBox="0 0 520 400" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto drop-shadow-2xl">
              <rect x="30" y="15" width="350" height="235" rx="12" stroke="#3BD5AE" stroke-width="2" fill="white" />
              <rect x="38" y="28" width="334" height="206" rx="4" fill="#f8fafc" />
              <rect x="38" y="28" width="70" height="206" fill="#e6f4f2" />
