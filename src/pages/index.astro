  }
  .ts-chip strong {
    color: #3BD5AE;
    display: block;
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 1px;
  }

  /* Lavender section tag */
  .ts-tag {
    display: inline-block;
    background: #E3DDF8;
    color: #134A45;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 6px 14px;
