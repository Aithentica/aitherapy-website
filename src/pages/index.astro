              <rect x="116" y="28" width="256" height="28" fill="#f1f5f9" />
              <rect x="126" y="38" width="80" height="6" rx="3" fill="#134A45" opacity="0.5" />
              <circle cx="352" cy="42" r="8" fill="#3BD5AE" opacity="0.3" />
