    document.querySelectorAll('#webinar-form-top, #webinar-form-bottom').forEach(form => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = form.querySelector('button[type="submit"]');
        const originalText = btn.textContent;
        btn.textContent = 'Wysyłanie...';
        btn.disabled = true;

        const formData = new FormData(form);
        const email = formData.get('email');
        const name = formData.get('name');
        const phone = formData.get('phone');

        try {
          const res = await fetch(MAILERLITE_API, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${MAILERLITE_KEY}`
            },
            body: JSON.stringify({
              email,
              fields: { name, phone: phone || '' },
              groups: [GROUP_ID]
            })
          });

          if (!res.ok) throw new Error('API error');

          form.innerHTML = `
            <div class="text-center py-8">
              <div class="text-4xl mb-4">🎉</div>
              <h3 class="text-2xl font-bold text-white mb-2">Dziękujemy!</h3>
              <p class="text-white/70 text-lg">Zarezerwowaliśmy Twoje miejsce. Szczegóły wyślemy na podany adres e-mail.</p>
            </div>
          `;
        } catch (err) {
          btn.textContent = originalText;
          btn.disabled = false;
          const errorDiv = form.querySelector('.form-error');
          if (errorDiv) errorDiv.remove();
          const div = document.createElement('div');
          div.className = 'form-error text-red-400 text-sm text-center mt-2';
          div.textContent = 'Wystąpił błąd. Spróbuj ponownie.';
          btn.after(div);
        }
      });
    });
  </script>

</PageLayout>
