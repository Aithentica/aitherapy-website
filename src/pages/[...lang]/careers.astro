---
import PageLayout from '../../layouts/PageLayout.astro';
import type { Locale } from '../../i18n/config';
import { getStaticLocalePaths, getLocaleFromParams, useTranslations, loadTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return getStaticLocalePaths();
}

const locale = getLocaleFromParams(Astro.params.lang) as Locale;
await loadTranslations(locale);
const t = useTranslations(locale);
const cp = t.careersPage;

const jobsPl = [
  {
    emoji: '🧠',
    title: 'Customer Success Manager',
    form: 'B2B, full-time',
    salary: '8 000 – 10 000 PLN netto/mc',
    location: 'Remote / Warszawa',
    about: 'Therapy Support to polska platforma SaaS dla psychoterapeutów CBT — automatyzujemy dokumentację sesji, generujemy notatki kliniczne i wspieramy prowadzenie gabinetu. Jesteśmy małym, zwinnym zespołem (CEO, CTO, psychoterapeutka-ekspertka) z realnym produktem i pierwszymi płacącymi klientami.',
    lookingFor: 'Szukamy osoby, która stanie się twarzą Therapy Support wobec naszych klientów — terapeutów, którzy potrzebują kogoś, kto ich wysłucha, wdroży i zadba o to, żeby platforma naprawdę działała dla nich.',
    tasks: [
      'Prowadzić wdrożenia 1:1 z nowymi terapeutami (Zoom, udostępnianie ekranu)',
      'Być pierwszym kontaktem dla klientów — odpowiadać na pytania, rozwiązywać problemy',
      'Weryfikować zgłoszenia — odróżniać błąd od pomyłki użytkownika, tworzyć precyzyjne zgłoszenia dla zespołu deweloperskiego',
      'Testować nowe funkcje przed wdrożeniem z perspektywy terapeuty',
      'Nagrywać krótkie filmy i poradniki do wdrażania nowych użytkowników i mediów społecznościowych',
      'Pisać o swoich doświadczeniach z klientami — posty, historie sukcesu, LinkedIn',
      'Budować bazę wiedzy i FAQ platformy',
      'Monitorować aktywność klientów i wyłapywać ryzyko porzucenia aplikacji',
    ],
    requirements: [
      'Osoby, która lubi rozmawiać z ludźmi i ma naturalną cierpliwość',
      'Kogoś niestroniącego od kamerki — nagrania, rolki, krótkie wideo to u nas standard',
      'Osoby, która chętnie pisze o tym co robi — LinkedIn, notatki, posty',
      'Z doświadczeniem w obsłudze klienta, CSM lub SaaS (nie wymagamy seniority)',
      'Ciekawości tematu psychoterapii / mental health — mile widziana',
      'Umiejętności dobrego opisywania problemów technicznych prostym językiem',
    ],
    aiBenefitIntro: '🤖 Praca w środowisku AI-first — to nasza największa zaleta',
    aiBenefitDesc: 'Jesteśmy firmą, gdzie AI nie jest dodatkiem — jest domyślnym sposobem pracy.',
    aiBenefits: [
      'Każdy w zespole ma Claude Pro opłacony przez firmę od pierwszego dnia',
      'Każdy proces — od wdrożenia, przez dokumentację, po komunikację — jest zaprojektowany z AI',
      'Nie musisz tracić czasu na rutynowe zadania — AI przygotowuje szkice, podsumowania, zgłoszenia, maile',
      'Twoje spotkania z klientami zostają nagrywane i transkrybowane — AI robi notatki za Ciebie',
      'Uczymy Cię jak pracować z AI naprawdę (nie tylko "użyj ChatGPT") — inwestujemy w rozwój umiejętności pracy z AI u każdego członka zespołu',
      'Pracujesz nad produktem, który sam jest oparty o AI — rozumiesz klienta od środka',
    ],
    aiQuote: 'W Therapy Support jedyna rzecz, której AI nie zastąpi, to relacja z klientem. I właśnie dlatego Cię szukamy.',
    perks: [
      '8 000 – 10 000 PLN netto / B2B',
      'Claude Pro opłacony przez firmę',
      'Pełny dostęp do naszego zestawu narzędzi AI',
      'Praca zdalna, elastyczne godziny',
      'Realny wpływ na produkt — Twoje uwagi trafiają prosto do zespołu',
      'Możliwość udziałów w firmie dla osób, które zostaną z nami na dłużej',
    ],
  },
  {
    emoji: '🚀',
    title: 'Partnerships & GTM Manager',
    form: 'B2B, full-time',
    salary: '10 500 – 14 500 PLN netto/mc base + success fees',
    location: 'Remote / Warszawa (podróże krajowe i zagraniczne)',
    about: 'Therapy Support to polska platforma SaaS dla psychoterapeutów CBT — automatyzujemy dokumentację sesji, generujemy notatki kliniczne i wspieramy prowadzenie gabinetu. Mamy partnerstwo badawcze z Instytutem Psychologii PAN, grant NCBR w toku i ambicje europejskie — chcemy być standardem dokumentacji CBT w UE.',
    lookingFor: 'Szukamy kogoś, kto stworzy strategię wejścia na rynek i będzie odpowiadał za jej wyniki — od pierwszego telefonu po podpisane partnerstwo z europejskim towarzystwem CBT.',
    tasks: [
      'Budować i realizować strategię wejścia na rynek dla kanału partnerskiego — szkoły psychoterapii, towarzystwa CBT, ośrodki szkoleniowe w Polsce i Europie',
      'Określać profil idealnego klienta, testować kanały wejścia, odpowiadać za wskaźniki — koszt pozyskania, konwersja, czas do zamknięcia',
      'Dzwonić, jeździć, prezentować i zamykać — licencje grupowe, pilotaże, rekomendacje w programach szkoleniowych',
      'Reprezentować Therapy Support na konferencjach (PTTPB Katowice maj 2026, EABCT Bruksela wrzesień 2026)',
      'Pojawiać się na naszych mediach społecznościowych — relacje z konferencji, kulisy pracy, własne refleksje z pracy w CBT SaaS',
      'Raportować do CEO — wskaźniki: lejek sprzedażowy, podpisane partnerstwa, przychód z kanału',
    ],
    requirements: [
      'Min. 5 lat w B2B sales, GTM lub partnership development',
      'Myślisz jak strateg, działasz jak handlowiec',
      'Płynny angielski — MUST',
      'Drugi język EU (niemiecki, francuski, hiszpański) = duży plus',
      'Nie boisz się kamery — nagrania, rolki, LinkedIn to u nas standard',
      'Doświadczenie w health-tech, edu-tech lub wellness = idealnie',
      'Gotowość do podróży 2–4 razy w miesiącu',
      'Samodzielność — budujesz od zera, bez gotowych instrukcji',
    ],
    aiBenefitIntro: '🤖 Praca w środowisku AI-first — to nasza największa zaleta',
    aiBenefitDesc: 'Jesteśmy firmą, gdzie AI nie jest dodatkiem — jest domyślnym sposobem pracy.',
    aiBenefits: [
      'Każdy w zespole ma Claude Pro opłacony przez firmę od pierwszego dnia',
      'Każdy proces jest zaprojektowany z AI — szkice, podsumowania, maile, prezentacje',
      'Twoje spotkania są nagrywane i transkrybowane — AI robi notatki za Ciebie',
      'Uczymy Cię jak pracować z AI naprawdę — nie tylko "użyj ChatGPT"',
      'Pracujesz nad produktem opartym o AI — rozumiesz klienta od środka',
    ],
    aiQuote: 'W Therapy Support jedyna rzecz, której AI nie zastąpi, to relacja z partnerem. I właśnie dlatego Cię szukamy.',
    perks: [
      '10 500 – 14 500 PLN netto podstawa / B2B',
      'Premia za sukces: 3 000 PLN za partnerstwo w PL, 5 000 PLN za zagraniczne',
      'Claude Pro opłacony przez firmę',
      'Pełny dostęp do zestawu narzędzi AI',
      'Praca zdalna, elastyczne godziny',
      'Realne zarządzanie strategią wejścia na rynek — budujesz dział od zera',
      'Udziały w firmie dla osób, które zostaną z nami na dłużej',
      'Bilet i akredytacja na PTTPB Katowice (maj 2026) i EABCT Bruksela (wrzesień 2026)',
    ],
  },
];

const jobsEn = [
  {
    emoji: '🧠',
    title: 'Customer Success Manager',
    form: 'B2B, full-time',
    salary: '8,000 – 10,000 PLN net/month',
    location: 'Remote / Warsaw',
    about: 'Therapy Support is a Polish SaaS platform for CBT psychotherapists — we automate session documentation, generate clinical notes, and support practice management. We are a small, agile team (CEO, CTO, expert psychotherapist) with a real product and first paying clients.',
    lookingFor: 'We are looking for someone who will become the face of Therapy Support for our clients — therapists who need someone to listen, onboard them, and ensure the platform truly works for them.',
    tasks: [
      'Run 1:1 onboarding sessions with new therapists (Zoom, screen share)',
      'Be the first point of contact for clients — answer questions, solve problems',
      'Validate reports — distinguish bugs from user errors, create precise dev tickets',
      'Test new features before release from a therapist\'s perspective',
      'Record short videos and tutorials for onboarding and social media',
      'Write about your client experiences — posts, case studies, LinkedIn',
      'Build the platform\'s knowledge base and FAQ',
      'Monitor client activity and identify churn risk',
    ],
    requirements: [
      'Someone who enjoys talking to people and has natural patience',
      'Comfortable on camera — recordings, reels, short videos are our standard',
      'Someone who likes writing about their work — LinkedIn, notes, posts',
      'Experience in customer service, CSM, or SaaS (seniority not required)',
      'Curiosity about psychotherapy / mental health — a plus',
      'Ability to describe technical problems in simple language',
    ],
    aiBenefitIntro: '🤖 Working in an AI-first environment — our biggest benefit',
    aiBenefitDesc: 'We are a company where AI is not an add-on — it\'s the default way of working.',
    aiBenefits: [
      'Everyone on the team gets Claude Pro paid by the company from day one',
      'Every process — from onboarding to documentation to communication — is designed with AI',
      'No time wasted on routine tasks — AI prepares drafts, summaries, tickets, emails',
      'Your client meetings are recorded and transcribed — AI takes notes for you',
      'We teach you how to really work with AI (not just "use ChatGPT") — we invest in AI fluency for every team member',
      'You work on a product built on AI — you understand the client from the inside',
    ],
    aiQuote: 'At Therapy Support, the only thing AI can\'t replace is the relationship with the client. And that\'s exactly why we\'re looking for you.',
    perks: [
      '8,000 – 10,000 PLN net / B2B',
      'Claude Pro paid by the company',
      'Full access to our AI tool stack',
      'Remote-first, flexible hours',
      'Real impact on the product — your feedback goes straight to the team',
      'Equity opportunity for those who stay with us long-term',
    ],
  },
  {
    emoji: '🚀',
    title: 'Partnerships & GTM Manager',
    form: 'B2B, full-time',
    salary: '10,500 – 14,500 PLN net/month base + success fees',
    location: 'Remote / Warsaw (domestic & international travel)',
    about: 'Therapy Support is a Polish SaaS platform for CBT psychotherapists — we automate session documentation, generate clinical notes, and support practice management. We have a research partnership with the Polish Academy of Sciences Institute of Psychology, an NCBR grant in progress, and European ambitions — we want to become the standard for CBT documentation in the EU.',
    lookingFor: 'We\'re looking for someone who will create the go-to-market strategy and own its results — from the first cold call to a signed partnership with a European CBT association.',
    tasks: [
      'Build and execute GTM strategy for the partnership channel — psychotherapy schools, CBT associations, training centers in Poland and Europe',
      'Define ICP, test entry channels, own metrics — CAC, conversion, time-to-close',
      'Call, travel, pitch, and close — group licenses, pilots, recommendations in training programs',
      'Represent Therapy Support at conferences (PTTPB Katowice May 2026, EABCT Brussels September 2026)',
      'Appear on our social media — conference coverage, behind the scenes, personal reflections on working in CBT SaaS',
      'Report to CEO — KPIs: pipeline, signed partnerships, channel revenue',
    ],
    requirements: [
      'Min. 5 years in B2B sales, GTM, or partnership development',
      'Think like a strategist, act like a salesperson',
      'Fluent English — MUST',
      'Second EU language (German, French, Spanish) = big plus',
      'Comfortable on camera — recordings, reels, LinkedIn is our standard',
      'Experience in health-tech, edu-tech, or wellness = ideal',
      'Willingness to travel 2–4 times per month',
      'Self-starter — you build from scratch, no existing playbook',
    ],
    aiBenefitIntro: '🤖 Working in an AI-first environment — our biggest benefit',
    aiBenefitDesc: 'We are a company where AI is not an add-on — it\'s the default way of working.',
    aiBenefits: [
      'Everyone on the team gets Claude Pro paid by the company from day one',
      'Every process is designed with AI — drafts, summaries, emails, presentations',
      'Your meetings are recorded and transcribed — AI takes notes for you',
      'We teach you how to really work with AI — not just "use ChatGPT"',
      'You work on a product built on AI — you understand the client from the inside',
    ],
    aiQuote: 'At Therapy Support, the only thing AI can\'t replace is the relationship with the partner. And that\'s exactly why we\'re looking for you.',
    perks: [
      '10,500 – 14,500 PLN net base / B2B',
      'Success fee: 3,000 PLN per Polish partnership, 5,000 PLN per international',
      'Claude Pro paid by the company',
      'Full access to our AI tool stack',
      'Remote-first, flexible hours',
      'Real GTM ownership — you build the department from scratch',
      'Equity for those who stay with us long-term',
      'Ticket and accreditation for PTTPB Katowice (May 2026) and EABCT Brussels (September 2026)',
    ],
  },
];

const jobs = locale === 'pl' ? jobsPl : jobsEn;
---

<PageLayout title={cp.title} description={cp.metaDesc} locale={locale}>
  <!-- Hero -->
  <section class="pt-16 lg:pt-24 pb-8 lg:pb-10 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="inline-flex items-center px-4 py-1.5 rounded-full bg-sage-50 border border-sage-200 text-sage-700 text-sm font-extrabold mb-6">{cp.heroTag}</p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight text-gray-900">{cp.heroTitle}</h1>
      <p class="mt-6 text-lg text-gray-600 leading-relaxed max-w-3xl mx-auto">{cp.heroDesc}</p>
    </div>
  </section>

  <!-- Master-detail layout -->
  <section class="pb-16 lg:pb-24 bg-sage-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row gap-6 lg:gap-8">

        <!-- Left sidebar — job list (1/3) -->
        <aside class="w-full lg:w-1/3 lg:sticky lg:top-24 lg:self-start">
          <h2 class="text-xl font-bold text-gray-900 mb-4">{cp.openPositions}</h2>
          <nav class="space-y-3">
            {jobs.map((job, i) => (
              <a
                href={`#job-${i}`}
                class="block bg-white rounded-xl p-5 shadow-sm border-2 border-transparent hover:border-brand-500 transition-colors group"
                data-job-card={i}
              >
                <div class="flex items-start gap-3">
                  <span class="text-2xl flex-shrink-0">{job.emoji}</span>
                  <div class="min-w-0">
                    <h3 class="font-bold text-gray-900 group-hover:text-brand-600 transition-colors leading-snug">{job.title}</h3>
                    <p class="text-sm text-gray-500 mt-1">{job.form}</p>
                    <p class="text-sm font-semibold text-brand-600 mt-1">{job.salary}</p>
                    <p class="text-xs text-gray-400 mt-1">{job.location}</p>
                  </div>
                </div>
              </a>
            ))}
          </nav>
        </aside>

        <!-- Right panel — job details (2/3) -->
        <main class="w-full lg:w-2/3 space-y-10">
          {jobs.map((job, i) => (
            <article id={`job-${i}`} class="bg-white rounded-2xl shadow-sm overflow-hidden scroll-mt-24">
              <!-- Job header -->
              <div class="bg-brand-500 px-6 sm:px-8 py-6">
                <h3 class="text-2xl font-bold text-white">{job.emoji} {job.title}</h3>
                <div class="flex flex-wrap gap-4 mt-3 text-brand-100 text-sm">
                  <span>{job.form}</span>
                  <span>•</span>
                  <span>{job.salary}</span>
                  <span>•</span>
                  <span>{job.location}</span>
                </div>
              </div>

              <div class="px-6 sm:px-8 py-8 space-y-8">
                <!-- About -->
                <div>
                  <p class="text-gray-700 leading-relaxed">{job.about}</p>
                  <p class="mt-4 text-gray-700 leading-relaxed font-medium">{job.lookingFor}</p>
                </div>

                <!-- Tasks -->
                <div>
                  <h4 class="text-lg font-bold text-gray-900 mb-3">{cp.sectionTasks}</h4>
                  <ul class="space-y-2">
                    {job.tasks.map((task) => (
                      <li class="flex items-start gap-2 text-gray-700">
                        <span class="text-brand-500 mt-1 flex-shrink-0">▸</span>
                        <span>{task}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                <!-- Requirements -->
                <div>
                  <h4 class="text-lg font-bold text-gray-900 mb-3">{cp.sectionRequirements}</h4>
                  <ul class="space-y-2">
                    {job.requirements.map((req) => (
                      <li class="flex items-start gap-2 text-gray-700">
                        <span class="text-brand-500 mt-1 flex-shrink-0">▸</span>
                        <span>{req}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                <!-- AI benefit -->
                <div class="bg-gray-50 rounded-xl p-6 border border-gray-100">
                  <h4 class="text-lg font-bold text-gray-900 mb-2">{job.aiBenefitIntro}</h4>
                  <p class="text-gray-600 mb-4">{job.aiBenefitDesc}</p>
                  <ul class="space-y-2">
                    {job.aiBenefits.map((benefit) => (
                      <li class="flex items-start gap-2 text-gray-700">
                        <span class="text-accent-400 mt-1 flex-shrink-0">✦</span>
                        <span>{benefit}</span>
                      </li>
                    ))}
                  </ul>
                  <p class="mt-4 text-gray-800 font-medium italic">{job.aiQuote}</p>
                </div>

                <!-- Perks -->
                <div>
                  <h4 class="text-lg font-bold text-gray-900 mb-3">{cp.sectionPerks}</h4>
                  <ul class="space-y-2">
                    {job.perks.map((perk) => (
                      <li class="flex items-start gap-2 text-gray-700">
                        <span class="text-brand-500 flex-shrink-0">✅</span>
                        <span>{perk}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                <!-- Apply -->
                <div class="bg-brand-50 rounded-xl p-6 border border-brand-200">
                  <h4 class="text-lg font-bold text-gray-900 mb-2">{cp.applyTitle}</h4>
                  <p class="text-gray-700 mb-3">{cp.applyDesc}</p>
                  <ol class="space-y-2 list-decimal list-inside text-gray-700">
                    <li>{cp.applyStep1}</li>
                    <li>{cp.applyStep2}</li>
                  </ol>
                  <p class="mt-4">
                    <a href={`mailto:${cp.applyEmail}`} class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-brand-500 text-white font-semibold hover:bg-brand-600 transition-colors">
                      {cp.applyEmail}
                    </a>
                  </p>
                </div>
              </div>
            </article>
          ))}
        </main>

      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll('[data-job-card]').forEach(card => {
      card.addEventListener('click', () => {
        document.querySelectorAll('[data-job-card]').forEach(c => c.classList.remove('!border-brand-500'));
        card.classList.add('!border-brand-500');
      });
    });
    // Highlight first card by default
    const first = document.querySelector('[data-job-card="0"]');
    if (first) first.classList.add('!border-brand-500');
  </script>
</PageLayout>
