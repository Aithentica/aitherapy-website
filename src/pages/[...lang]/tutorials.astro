---
import PageLayout from '../../layouts/PageLayout.astro';
import { getStaticLocalePaths, getLocaleFromParams, useTranslations, loadTranslations } from '../../i18n/utils';
import type { Locale } from '../../i18n/config';
import { YOUTUBE_API_KEY, PLAYLIST_IDS, YOUTUBE_CHANNEL_URL } from '../../data/youtube';

export function getStaticPaths() {
  return getStaticLocalePaths();
}

const locale = getLocaleFromParams(Astro.params.lang) as Locale;
await loadTranslations(locale);
const t = useTranslations(locale);

const playlistId = PLAYLIST_IDS[locale];
---

<PageLayout title={t.tutorialsPage.title} description={t.tutorialsPage.metaDesc} locale={locale}>
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-6">
      <!-- Header -->
      <div class="mb-12 text-center">
        <span class="mb-4 inline-block rounded-full bg-brand-50 px-4 py-1.5 text-sm font-medium text-brand-600">
          {t.tutorialsPage.heading}
        </span>
        <h1 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          {t.tutorialsPage.heading}
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600 leading-relaxed">
          {t.tutorialsPage.subtitle}
        </p>
      </div>

      <!-- Loading state -->
      <div id="tutorials-loading" class="flex flex-col items-center justify-center py-16">
        <div class="h-10 w-10 animate-spin rounded-full border-4 border-brand-200 border-t-brand-500"></div>
        <p class="mt-4 text-gray-500">{t.tutorialsPage.loading}</p>
      </div>

      <!-- Error state (hidden by default) -->
      <div id="tutorials-error" class="hidden py-16 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
        </svg>
        <p class="mt-4 text-gray-500">{t.tutorialsPage.errorLoading}</p>
      </div>

      <!-- Empty state (hidden by default) -->
      <div id="tutorials-empty" class="hidden py-16 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z" />
        </svg>
        <p class="mt-4 text-gray-500">{t.tutorialsPage.noVideos}</p>
      </div>

      <!-- Video grid -->
      <div id="tutorials-grid" class="hidden grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      </div>

      <!-- YouTube channel link -->
      <div id="tutorials-footer" class="mt-12 hidden text-center">
        <a
          href={YOUTUBE_CHANNEL_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full bg-brand-500 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-brand-600"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/>
            <polygon fill="#fff" points="9.545,15.568 15.818,12 9.545,8.432"/>
          </svg>
          {t.tutorialsPage.allTutorials}
        </a>
      </div>
    </div>
  </section>

  <!-- Video modal -->
  <div id="video-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 p-4 backdrop-blur-sm">
    <div class="relative w-full max-w-4xl">
      <button
        id="modal-close"
        class="absolute -top-10 right-0 text-white hover:text-gray-300 transition-colors"
        aria-label="Close"
      >
        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      <div class="aspect-video w-full overflow-hidden rounded-xl bg-black shadow-2xl">
        <iframe
          id="modal-iframe"
          class="h-full w-full"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </div>

  <script define:vars={{ apiKey: YOUTUBE_API_KEY, playlistId, watchOnYoutube: t.tutorialsPage.watchOnYoutube }}>
    async function loadTutorials() {
      const loading = document.getElementById('tutorials-loading');
      const error = document.getElementById('tutorials-error');
      const empty = document.getElementById('tutorials-empty');
      const grid = document.getElementById('tutorials-grid');
      const footer = document.getElementById('tutorials-footer');

      try {
        const url = `https://www.googleapis.com/youtube/v3/playlistItems?part=snippet&maxResults=50&playlistId=${playlistId}&key=${apiKey}`;
        const res = await fetch(url);

        if (!res.ok) throw new Error(`API error: ${res.status}`);

        const data = await res.json();
        const items = (data.items || []).filter(
          (item) => item.snippet.title !== 'Private video' && item.snippet.title !== 'Deleted video'
        );

        loading.classList.add('hidden');

        if (items.length === 0) {
          empty.classList.remove('hidden');
          return;
        }

        // Build video cards
        grid.innerHTML = items.map((item) => {
          const { title, thumbnails, resourceId, description } = item.snippet;
          const videoId = resourceId.videoId;
          const thumb = thumbnails.high?.url || thumbnails.medium?.url || thumbnails.default?.url;
          const shortDesc = description
            ? description.length > 120 ? description.substring(0, 120) + '...' : description
            : '';

          return `
            <button
              class="group cursor-pointer rounded-2xl border border-gray-100 bg-white text-left shadow-sm transition-all duration-200 hover:shadow-lg hover:border-brand-200 overflow-hidden focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2"
              data-video-id="${videoId}"
              onclick="openVideo('${videoId}')"
            >
              <div class="relative aspect-video overflow-hidden">
                <img
                  src="${thumb}"
                  alt="${title.replace(/"/g, '&quot;')}"
                  class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 flex items-center justify-center bg-black/0 transition-colors group-hover:bg-black/20">
                  <div class="flex h-14 w-14 items-center justify-center rounded-full bg-brand-500 text-white opacity-90 shadow-lg transition-transform group-hover:scale-110">
                    <svg class="ml-1 h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  </div>
                </div>
              </div>
              <div class="p-4">
                <h3 class="line-clamp-2 text-sm font-semibold text-gray-900 group-hover:text-brand-600 transition-colors">
                  ${title}
                </h3>
                ${shortDesc ? `<p class="mt-2 line-clamp-2 text-xs text-gray-500">${shortDesc}</p>` : ''}
              </div>
            </button>
          `;
        }).join('');

        grid.classList.remove('hidden');
        footer.classList.remove('hidden');

      } catch (err) {
        console.error('Failed to load tutorials:', err);
        loading.classList.add('hidden');
        error.classList.remove('hidden');
      }
    }

    // Modal logic
    const modal = document.getElementById('video-modal');
    const iframe = document.getElementById('modal-iframe');
    const closeBtn = document.getElementById('modal-close');

    window.openVideo = function(videoId) {
      iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0`;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    };

    closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });

    function closeModal() {
      iframe.src = '';
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    }

    // Load on page ready
    loadTutorials();
  </script>
</PageLayout>
