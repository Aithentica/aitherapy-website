---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import TrustLogos from '../../components/sections/TrustLogos.astro';
import type { Locale } from '../../i18n/config';
import { getStaticLocalePaths, getLocaleFromParams, useTranslations, loadTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return getStaticLocalePaths();
}

const locale = getLocaleFromParams(Astro.params.lang) as Locale;
await loadTranslations(locale);
const t = useTranslations(locale);
const bt = t.betatester;

const iconSvg: Record<string, string> = {
  Users: `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  UserCircle: `<circle cx="12" cy="12" r="10"/><circle cx="12" cy="10" r="3"/><path d="M7 20.662V19a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v1.662"/>`,
  Calendar: `<path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/>`,
  StickyNote: `<path d="M16 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8Z"/><path d="M15 3v4a2 2 0 0 0 2 2h4"/>`,
  CreditCard: `<rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/>`,
  Mail: `<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>`,
  MessageSquare: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
  Settings: `<path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/>`,
  Mic: `<path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/>`,
  Brain: `<path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/>`,
  Headphones: `<path d="M3 14h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7a9 9 0 0 1 18 0v7a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3"/>`,
  UserRoundCog: `<path d="M2 21a8 8 0 0 1 10.434-7.62"/><path d="m19.5 14.3-.4.9"/><path d="m16.9 20.8-.4.9"/><path d="m21.7 19.5-.9-.4"/><path d="m15.2 16.9-.9-.4"/><path d="m21.7 16.5-.9.4"/><path d="m15.2 19.1-.9.4"/><path d="m19.5 21.7-.4-.9"/><path d="m16.9 15.2-.4-.9"/><circle cx="10" cy="8" r="5"/><circle cx="18" cy="18" r="3"/>`,
  ChartNoAxesCombined: `<path d="M12 16v5"/><path d="M16 14v7"/><path d="M20 10v11"/><path d="m22 3-8.646 8.646a.5.5 0 0 1-.708 0L9.354 8.354a.5.5 0 0 0-.707 0L2 15"/><path d="M4 18v3"/><path d="M8 14v7"/>`,
};

const featureIcons = ['Users','UserCircle','Calendar','StickyNote','CreditCard','Mail','MessageSquare','Settings','Mic','Brain','ChartNoAxesCombined','Headphones','UserRoundCog'];
const featureColors = [
  { bg: 'bg-indigo-50', border: 'border-indigo-100', color: 'text-indigo-600' },
  { bg: 'bg-purple-50', border: 'border-purple-100', color: 'text-purple-600' },
  { bg: 'bg-teal-50', border: 'border-teal-100', color: 'text-teal-600' },
  { bg: 'bg-amber-50', border: 'border-amber-100', color: 'text-amber-600' },
  { bg: 'bg-green-50', border: 'border-green-100', color: 'text-green-600' },
  { bg: 'bg-blue-50', border: 'border-blue-100', color: 'text-blue-600' },
  { bg: 'bg-pink-50', border: 'border-pink-100', color: 'text-pink-600' },
  { bg: 'bg-slate-50', border: 'border-slate-200', color: 'text-slate-600' },
  { bg: 'bg-red-50', border: 'border-red-100', color: 'text-red-600' },
  { bg: 'bg-violet-50', border: 'border-violet-100', color: 'text-violet-600' },
  { bg: 'bg-cyan-50', border: 'border-cyan-100', color: 'text-cyan-600' },
  { bg: 'bg-orange-50', border: 'border-orange-100', color: 'text-orange-600' },
  { bg: 'bg-emerald-50', border: 'border-emerald-100', color: 'text-emerald-600' },
];

const checkSvg = `<path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/>`;
---

<BaseLayout title={bt.title} description={bt.metaDesc} locale={locale}>
  <Header locale={locale} />

  <main class="min-h-screen bg-slate-50">
    <!-- HERO -->
    <div class="bg-gradient-to-br from-brand-500 via-brand-600 to-brand-700 text-white">
      <div class="max-w-6xl mx-auto px-6 py-12">
        <div class="grid lg:grid-cols-2 gap-10 items-center">
          <div class="flex flex-col justify-center">
            <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm text-white text-sm font-bold px-5 py-2 rounded-full mb-6 border border-white/20 self-start">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 0 1-1.5 1.5H5.25a1.5 1.5 0 0 1-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 1 0 9.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1 1 14.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" /></svg>
              {bt.badge}
            </div>
            <h1 class="font-display text-3xl md:text-4xl font-bold mb-4">{bt.heading}</h1>
            <p class="text-lg text-white/80 max-w-xl mb-8">
              {bt.introStart} <span class="font-bold text-white">{bt.introFree}</span> {bt.introAfter} <span class="font-bold text-white">{bt.introDiscount}</span> {bt.introEnd}
            </p>
            <div class="flex flex-col sm:flex-row items-start gap-4 sm:gap-6 max-w-xl">
              <div class="flex items-center gap-3 bg-white/10 backdrop-blur-sm rounded-xl px-5 py-3 border border-white/15">
                <div class="w-8 h-8 rounded-full bg-accent-400/20 flex items-center justify-center border border-accent-400/30 flex-shrink-0">
                  <svg class="w-4 h-4 text-accent-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 0 1-1.5 1.5H5.25a1.5 1.5 0 0 1-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 1 0 9.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1 1 14.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" /></svg>
                </div>
                <div class="text-left">
                  <p class="text-xs text-white/60 font-medium">{bt.first5Weeks}</p>
                  <p class="text-lg font-bold text-white">{bt.free}</p>
                </div>
              </div>
              <svg class="w-5 h-5 text-white/40 hidden sm:block flex-shrink-0 mt-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
              <div class="flex items-center gap-3 bg-white/10 backdrop-blur-sm rounded-xl px-5 py-3 border border-white/15">
                <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0" style="background:rgba(167,139,250,0.25);border:1px solid rgba(167,139,250,0.4)">
                  <svg class="w-4 h-4" style="color:#c4b5fd" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" /></svg>
                </div>
                <div class="text-left">
                  <p class="text-xs text-white/60 font-medium">{bt.thenForever}</p>
                  <p class="text-lg font-bold text-white">{bt.withDiscount}</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Pricing card -->
          <div class="w-full max-w-md mx-auto lg:mx-0">
            <div class="relative bg-white rounded-2xl border-2 border-brand-400 shadow-2xl p-6 text-slate-900"
              data-locale={locale}
              data-t-monthly={bt.monthly}
              data-t-yearly={bt.yearly}
              data-t-per-month={bt.perMonth}
              data-t-per-year={bt.perYear}
              data-t-saving-prefix={bt.yearlySavingPrefix}
              data-t-saving-suffix={bt.yearlySavingSuffix}
              data-t-currency={bt.currency}
              data-t-error-email={bt.errorEmail}
              data-t-error-phone={bt.errorPhone}
              data-t-error-consent={bt.errorConsent}
              data-t-error-plan={bt.errorPlan}
              data-t-error-payment={bt.errorPayment}
              data-t-redirecting={bt.redirecting}
              data-t-submit={bt.submitButton}
              data-t-submit-message={bt.submitMessage}
              id="pricing-card"
            >
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="bg-brand-500 text-accent-400 text-xs font-bold px-4 py-1.5 rounded-full whitespace-nowrap flex items-center gap-1.5">
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 0 1-1.5 1.5H5.25a1.5 1.5 0 0 1-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 1 0 9.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1 1 14.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" /></svg>
                  {bt.betaOffer}
                </span>
              </div>

              <div class="text-center mt-4 mb-4">
                <h3 class="text-xl font-bold text-slate-900">{bt.professional}</h3>
              </div>

              <div class="flex justify-center mb-4">
                <div class="inline-flex items-center bg-slate-100 rounded-xl p-1">
                  <button id="toggle-monthly" class="px-4 py-2 rounded-lg text-sm font-semibold transition-all bg-brand-500 text-white shadow-sm">{bt.monthly}</button>
                  <button id="toggle-yearly" class="px-4 py-2 rounded-lg text-sm font-semibold transition-all text-slate-600 hover:text-slate-900 flex items-center gap-1.5">
                    {bt.yearly}
                    <span id="yearly-badge" class="text-xs px-1.5 py-0.5 rounded-full font-bold bg-emerald-50 text-emerald-700 border border-emerald-100">{bt.yearlyBadge}</span>
                  </button>
                </div>
              </div>

              <div class="bg-emerald-50 border border-emerald-100 rounded-xl p-4 mb-4 text-center">
                <p class="text-lg font-bold text-emerald-800">{bt.trialInfo}</p>
                <p class="text-sm text-emerald-600 mt-1">{bt.trialInfoSub}</p>
              </div>

              <div class="text-center mb-4">
                <p class="text-xs text-slate-500 mb-1 font-medium">{bt.priceAfterTrial}</p>
                <div class="flex items-center justify-center gap-2 mb-1 flex-wrap">
                  <span id="original-price" class="text-base text-slate-400 line-through">399 PLN</span>
                  <span class="bg-emerald-50 text-emerald-700 text-xs font-bold px-2 py-0.5 rounded-full border border-emerald-100">{bt.betaBadge}</span>
                  <span id="badge-17" class="hidden bg-violet-50 text-violet-700 text-xs font-bold px-2 py-0.5 rounded-full border border-violet-100">{bt.yearlyBadge}</span>
                </div>
                <div class="flex items-baseline justify-center gap-1">
                  <span id="price-display" class="text-3xl font-bold text-slate-900">279 PLN</span>
                  <span id="price-period" class="text-slate-400 text-sm">{bt.perMonth}</span>
                </div>
                <p id="yearly-saving" class="text-sm text-emerald-600 font-medium mt-1 hidden"></p>
                <p class="text-xs text-brand-500 font-semibold mt-1">{bt.discountForever}</p>
              </div>

              <div class="flex items-center justify-center gap-2 mb-4 pb-4 border-b border-slate-100">
                <svg class="w-5 h-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>
                <span class="text-sm font-bold text-slate-900">{bt.unlimitedPatients}</span>
              </div>

              <div id="signup-form">
                <div class="space-y-3 mb-4">
                  <div>
                    <label for="beta-email" class="block text-xs font-medium text-slate-600 mb-1">{bt.emailLabel}</label>
                    <input type="email" id="beta-email" placeholder={bt.emailPlaceholder}
                      class="w-full px-3 py-2.5 rounded-lg border border-slate-200 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" />
                  </div>
                  <div>
                    <label for="beta-phone" class="block text-xs font-medium text-slate-600 mb-1">{bt.phoneLabel}</label>
                    <input type="tel" id="beta-phone" placeholder={bt.phonePlaceholder}
                      class="w-full px-3 py-2.5 rounded-lg border border-slate-200 text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" />
                  </div>
                  <label class="flex items-start gap-2 cursor-pointer">
                    <input type="checkbox" id="beta-consent"
                      class="mt-0.5 w-4 h-4 rounded border-slate-300 text-brand-500 focus:ring-brand-500" />
                    <span class="text-xs text-slate-500">
                      {bt.consentPrefix} <a href="/regulamin/" target="_blank" class="text-brand-500 hover:underline">{bt.termsLink}</a> {bt.andText} <a href="/polityka-prywatnosci/" target="_blank" class="text-brand-500 hover:underline">{bt.privacyLink}</a>
                    </span>
                  </label>
                </div>

                <div id="beta-error" class="hidden mb-3 p-3 bg-red-50 border border-red-100 rounded-lg text-sm text-red-700"></div>

                <button id="beta-submit"
                  class="w-full py-3.5 px-6 bg-brand-500 hover:bg-brand-600 text-white rounded-xl font-bold text-base transition-all shadow-lg disabled:opacity-50 disabled:cursor-not-allowed">
                  {bt.submitButton}
                </button>
                <p class="text-center text-slate-400 text-xs mt-2">
                  {bt.cardDisclaimer1} <strong class="text-slate-500">{bt.cardDisclaimer2}</strong> {bt.cardDisclaimer3}
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <TrustLogos locale={locale} />

    <div class="max-w-5xl mx-auto py-10 px-6">
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 text-center mb-8">{bt.benefitsTitle}</h2>
        <div class="grid md:grid-cols-2 gap-6 mb-6">
          <div class="bg-white rounded-2xl border border-slate-200 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center border flex-shrink-0" style="background:rgba(59,213,174,0.08);border-color:rgba(59,213,174,0.2)">
                <svg class="w-4 h-4 text-brand-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z" /></svg>
              </div>
              {bt.testingTitle}
            </h3>
            <ul class="space-y-3">
              {[bt.testingItem1, bt.testingItem2, bt.testingItem3].map((item) => (
                <li class="flex items-start gap-3 text-sm text-slate-700">
                  <svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><Fragment set:html={checkSvg} /></svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-white rounded-2xl border border-slate-200 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
              <div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center border border-emerald-100 flex-shrink-0">
                <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" /></svg>
              </div>
              {bt.offerTitle}
            </h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-sm text-slate-700"><svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><Fragment set:html={checkSvg} /></svg><span><strong>{bt.offerItem1Bold}</strong> {bt.offerItem1}</span></li>
              <li class="flex items-start gap-3 text-sm text-slate-700"><svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><Fragment set:html={checkSvg} /></svg><span>{bt.offerItem2}</span></li>
              <li class="flex items-start gap-3 text-sm text-slate-700"><svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><Fragment set:html={checkSvg} /></svg><span>{bt.offerItem3}</span></li>
            </ul>
          </div>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white rounded-2xl border border-slate-200 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
              <div class="w-8 h-8 rounded-lg bg-amber-50 flex items-center justify-center border border-amber-100 flex-shrink-0">
                <svg class="w-4 h-4 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" /></svg>
              </div>
              {bt.roleTitle}
            </h3>
            <ul class="space-y-3">
              {[bt.roleItem1, bt.roleItem2, bt.roleItem3].map((item) => (
                <li class="flex items-start gap-3 text-sm text-slate-700"><svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><Fragment set:html={checkSvg} /></svg><span>{item}</span></li>
              ))}
            </ul>
          </div>
          <div class="bg-white rounded-2xl border border-slate-200 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
              <div class="w-8 h-8 rounded-lg bg-purple-50 flex items-center justify-center border border-purple-100 flex-shrink-0">
                <svg class="w-4 h-4 text-purple-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>
              </div>
              {bt.whyTitle}
            </h3>
            <p class="text-sm text-slate-700 leading-relaxed">{bt.whyDesc1}</p>
            <p class="text-sm text-slate-700 leading-relaxed mt-3">{bt.whyDesc2}</p>
          </div>
        </div>
      </div>

      <div class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 text-center mb-2">{bt.packageTitle}</h2>
        <p class="text-center text-slate-500 mb-8">{bt.packageSubtitle}</p>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4 max-w-3xl mx-auto">
          {bt.featureNames.map((name, i) => (
            <div class="flex items-center gap-2 text-sm text-slate-700">
              <div class={`w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0 shadow-sm ${featureColors[i].bg} border ${featureColors[i].border}`}>
                <svg class={`w-3.5 h-3.5 ${featureColors[i].color}`} fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" set:html={iconSvg[featureIcons[i]] ?? checkSvg}></svg>
              </div>
              <span class="font-medium text-xs">{name}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="flex justify-center gap-6 mb-10 flex-wrap">
        <div class="flex items-center gap-2 text-slate-500 text-sm">
          <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>
          <span>{bt.securedByStripe}</span>
        </div>
        <div class="flex items-center gap-2 text-slate-500 text-sm">
          <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><Fragment set:html={checkSvg} /></svg>
          <span>{bt.cancelAnytime}</span>
        </div>
        <div class="flex items-center gap-2 text-slate-500 text-sm">
          <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 0 1-1.5 1.5H5.25a1.5 1.5 0 0 1-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 1 0 9.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1 1 14.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" /></svg>
          <span>{bt.discountForeverBadge}</span>
        </div>
      </div>

      <div class="mt-16 text-center pb-10">
        <p class="text-slate-500">
          {bt.questions}
          <a href="mailto:kontakt@aitherapy.support" class="text-brand-500 hover:text-brand-600 font-medium">kontakt@aitherapy.support</a>
        </p>
        <p class="text-slate-400 text-sm mt-2">
          {bt.contactPerson}
          <a href="tel:+48662096201" class="text-brand-500 hover:text-brand-600">+48 662 096 201</a>
        </p>
      </div>
    </div>
  </main>

  <Footer locale={locale} />
</BaseLayout>

<script is:inline>
  var API_BASE = 'https://app.aitherapy.support';
  var BETA_COUPON_ID = 'promo_1Sz2UvALc8BRQ1zZG52z9NDN';
  var BETA_TRIAL_DAYS = 35;
  var BETA_DISCOUNT = 0.30;

  var card = document.getElementById('pricing-card');
  var T = {
    perMonth: card.getAttribute('data-t-per-month'),
    perYear: card.getAttribute('data-t-per-year'),
    savingPrefix: card.getAttribute('data-t-saving-prefix'),
    savingSuffix: card.getAttribute('data-t-saving-suffix'),
    currency: card.getAttribute('data-t-currency'),
    errorEmail: card.getAttribute('data-t-error-email'),
    errorPhone: card.getAttribute('data-t-error-phone'),
    errorConsent: card.getAttribute('data-t-error-consent'),
    errorPlan: card.getAttribute('data-t-error-plan'),
    errorPayment: card.getAttribute('data-t-error-payment'),
    redirecting: card.getAttribute('data-t-redirecting'),
    submit: card.getAttribute('data-t-submit'),
    submitMessage: card.getAttribute('data-t-submit-message'),
    locale: card.getAttribute('data-locale'),
  };

  var billingPeriod = 'monthly';
  var plans = [];

  var btnM = document.getElementById('toggle-monthly');
  var btnY = document.getElementById('toggle-yearly');
  var priceEl = document.getElementById('price-display');
  var periodEl = document.getElementById('price-period');
  var savingEl = document.getElementById('yearly-saving');
  var yearlyBadge = document.getElementById('yearly-badge');
  var originalPrice = document.getElementById('original-price');
  var badge17 = document.getElementById('badge-17');
  var submitBtn = document.getElementById('beta-submit');
  var errorEl = document.getElementById('beta-error');

  var FALLBACK_PLANS = [
    { code: 'professional', billingPeriodId: 1, price: 399, stripePriceId: 'price_1SagKmALc8BRQ1zZ8syDMaJD' },
    { code: 'professional', billingPeriodId: 2, price: 3990, stripePriceId: 'price_1SagKgALc8BRQ1zZH1bFwFEW' }
  ];

  fetch(API_BASE + '/api/stripe/plans', { credentials: 'include' })
    .then(function(r) { if (!r.ok) throw new Error(); return r.json(); })
    .then(function(data) { plans = data; updatePriceDisplay(); })
    .catch(function() { plans = FALLBACK_PLANS; updatePriceDisplay(); });

  function getSelectedPlan() {
    var periodId = billingPeriod === 'yearly' ? 2 : 1;
    for (var i = 0; i < plans.length; i++) {
      if (plans[i].code === 'professional' && plans[i].billingPeriodId === periodId) return plans[i];
    }
    return null;
  }

  function formatPrice(price) {
    return Math.round(price) + ' ' + T.currency;
  }

  function updatePriceDisplay() {
    var plan = getSelectedPlan();
    if (!plan) return;
    var fullPrice = plan.price;
    var betaPrice = Math.round(fullPrice * (1 - BETA_DISCOUNT));
    if (billingPeriod === 'monthly') {
      originalPrice.textContent = formatPrice(fullPrice);
      priceEl.textContent = formatPrice(betaPrice);
      periodEl.textContent = T.perMonth;
      badge17.classList.add('hidden');
      savingEl.classList.add('hidden');
    } else {
      originalPrice.textContent = formatPrice(fullPrice);
      priceEl.textContent = formatPrice(betaPrice);
      periodEl.textContent = T.perYear;
      badge17.classList.remove('hidden');
      savingEl.classList.remove('hidden');
      var monthlyPlan = null;
      for (var i = 0; i < plans.length; i++) {
        if (plans[i].code === 'professional' && plans[i].billingPeriodId === 1) { monthlyPlan = plans[i]; break; }
      }
      if (monthlyPlan) {
        var saving = monthlyPlan.price * 12 - betaPrice;
        savingEl.textContent = T.savingPrefix + Math.round(saving) + ' ' + T.currency + T.savingSuffix;
      }
    }
  }

  function setMonthly() {
    billingPeriod = 'monthly';
    btnM.className = 'px-4 py-2 rounded-lg text-sm font-semibold transition-all bg-brand-500 text-white shadow-sm';
    btnY.className = 'px-4 py-2 rounded-lg text-sm font-semibold transition-all text-slate-600 hover:text-slate-900 flex items-center gap-1.5';
    yearlyBadge.className = 'text-xs px-1.5 py-0.5 rounded-full font-bold bg-emerald-50 text-emerald-700 border border-emerald-100';
    updatePriceDisplay();
  }
  function setYearly() {
    billingPeriod = 'yearly';
    btnY.className = 'px-4 py-2 rounded-lg text-sm font-semibold transition-all bg-brand-500 text-white shadow-sm flex items-center gap-1.5';
    btnM.className = 'px-4 py-2 rounded-lg text-sm font-semibold transition-all text-slate-600 hover:text-slate-900';
    yearlyBadge.className = 'text-xs px-1.5 py-0.5 rounded-full font-bold bg-white/20 text-white';
    updatePriceDisplay();
  }
  btnM.addEventListener('click', setMonthly);
  btnY.addEventListener('click', setYearly);

  function showError(msg) { errorEl.textContent = msg; errorEl.classList.remove('hidden'); }
  function hideError() { errorEl.classList.add('hidden'); }

  submitBtn.addEventListener('click', function() {
    hideError();
    var email = document.getElementById('beta-email').value.trim();
    var phone = document.getElementById('beta-phone').value.trim();
    var consent = document.getElementById('beta-consent').checked;
    if (!email) { showError(T.errorEmail); return; }
    if (!phone) { showError(T.errorPhone); return; }
    if (!consent) { showError(T.errorConsent); return; }
    var plan = getSelectedPlan();
    if (!plan || !plan.stripePriceId) { showError(T.errorPlan); return; }
    submitBtn.disabled = true;
    submitBtn.textContent = T.redirecting;
    var body = {
      priceId: plan.stripePriceId,
      email: email,
      phoneNumber: phone,
      successUrl: window.location.origin + window.location.pathname + '?success=1',
      cancelUrl: window.location.origin + window.location.pathname,
      language: T.locale,
      couponId: BETA_COUPON_ID,
      trialDays: BETA_TRIAL_DAYS,
      submitMessage: T.submitMessage
    };
    fetch(API_BASE + '/api/stripe/create-checkout-session', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      body: JSON.stringify(body)
    })
    .then(function(r) {
      if (!r.ok) return r.json().then(function(data) { throw new Error(data.error || T.errorPayment); });
      return r.json();
    })
    .then(function(data) {
      if (data.sessionUrl) window.location.href = data.sessionUrl;
      else throw new Error(T.errorPayment);
    })
    .catch(function(err) {
      showError(err.message || T.errorPayment);
      submitBtn.disabled = false;
      submitBtn.textContent = T.submit;
    });
  });
</script>
