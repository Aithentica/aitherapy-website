---
import PageLayout from '../../layouts/PageLayout.astro';
import type { Locale } from '../../i18n/config';
import { getStaticLocalePaths, getLocaleFromParams, useTranslations, loadTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return getStaticLocalePaths();
}

const locale = getLocaleFromParams(Astro.params.lang) as Locale;
await loadTranslations(locale);
const t = useTranslations(locale);
const ap = t.aboutPage;

const team = [
  { name: 'Joanna Głowacka', role: ap.joannaRole, bio: ap.joannaBio, image: '/images/team/joanna-glowacka.jpeg' },
  { name: 'Bohdan Głowacki', role: ap.bohdanRole, bio: ap.bohdanBio, image: '/images/team/bohdan-glowacki.png' },
  { name: 'Bartłomiej Głowacki', role: ap.bartlomiejRole, bio: ap.bartlomiejBio, image: '/images/team/bartlomiej-glowacki.png' },
  { name: 'Ewa Cylwik', role: ap.ewaRole, bio: ap.ewaBio, image: '/images/team/ewa-cylwik.jpeg' },
];
---

<PageLayout title={ap.title} description={ap.metaDesc} locale={locale}>
  <section class="pt-16 lg:pt-24 pb-12 lg:pb-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="inline-flex items-center px-4 py-1.5 rounded-full bg-sage-50 border border-sage-200 text-sage-700 text-sm font-extrabold mb-6">{ap.teamTag}</p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight text-gray-900">{ap.heading}</h1>
      <p class="mt-6 text-lg text-gray-600 leading-relaxed">{ap.intro1}</p>
      <p class="mt-4 text-lg text-gray-600 leading-relaxed">{ap.intro2}</p>
    </div>
  </section>

  <section class="pt-8 lg:pt-12 pb-16 lg:pb-24 bg-sage-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-16">
        {team.map((member) => (
          <div class="flex flex-col md:flex-row gap-8 items-start bg-white rounded-2xl p-8 shadow-sm">
            <div class="flex-shrink-0">
              <img src={member.image} alt={member.name} class="w-48 h-48 rounded-2xl object-cover" />
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-bold text-gray-900 mb-2">{member.name}</h3>
              <p class="text-sage-600 font-semibold mb-4">{member.role}</p>
              <p class="text-gray-700 leading-relaxed">{member.bio}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
