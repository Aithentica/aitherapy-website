---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const APP_CHECKOUT_URL = 'https://app.aitherapy.support/betatester';

const clinicLogos = [
  { name: 'Sanitas Centrum Medyczne', logo: '/images/trust/partner-1.png' },
  { name: 'Lubelska Medycyna', logo: '/images/trust/partner-2.png' },
  { name: 'Microsoft for Startups', logo: '/images/logos/microsoft-for-startups.png' },
  { name: 'Unicorn Hub', logo: '/images/trust/unicorn-hub.png' },
];

const iconSvg: Record<string, string> = {
  Users: `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  UserCircle: `<circle cx="12" cy="12" r="10"/><circle cx="12" cy="10" r="3"/><path d="M7 20.662V19a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v1.662"/>`,
  Calendar: `<path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/>`,
  StickyNote: `<path d="M16 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8Z"/><path d="M15 3v4a2 2 0 0 0 2 2h4"/>`,
  CreditCard: `<rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/>`,
  Mail: `<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>`,
  MessageSquare: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
  Settings: `<path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/>`,
  Mic: `<path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/>`,
  Brain: `<path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/>`,
  Headphones: `<path d="M3 14h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7a9 9 0 0 1 18 0v7a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3"/>`,
  UserRoundCog: `<path d="M2 21a8 8 0 0 1 10.434-7.62"/><path d="m19.5 14.3-.4.9"/><path d="m16.9 20.8-.4.9"/><path d="m21.7 19.5-.9-.4"/><path d="m15.2 16.9-.9-.4"/><path d="m21.7 16.5-.9.4"/><path d="m15.2 19.1-.9.4"/><path d="m19.5 21.7-.4-.9"/><path d="m16.9 15.2-.4-.9"/><circle cx="10" cy="8" r="5"/><circle cx="18" cy="18" r="3"/>`,
  ChartNoAxesCombined: `<path d="M12 16v5"/><path d="M16 14v7"/><path d="M20 10v11"/><path d="m22 3-8.646 8.646a.5.5 0 0 1-.708 0L9.354 8.354a.5.5 0 0 0-.707 0L2 15"/><path d="M4 18v3"/><path d="M8 14v7"/>`,
};

const features = [
  { name: 'Portal pacjentów', icon: 'Users', bg: 'bg-indigo-50', border: 'border-indigo-100', color: 'text-indigo-600' },
  { name: 'Podstawowy panel terapeuty', icon: 'UserCircle', bg: 'bg-purple-50', border: 'border-purple-100', color: 'text-purple-600' },
  { name: 'Kalendarz sesji', icon: 'Calendar', bg: 'bg-teal-50', border: 'border-teal-100', color: 'text-teal-600' },
  { name: 'Notatki z sesji', icon: 'StickyNote', bg: 'bg-amber-50', border: 'border-amber-100', color: 'text-amber-600' },
  { name: 'Automatyzacja płatności i rozliczeń', icon: 'CreditCard', bg: 'bg-green-50', border: 'border-green-100', color: 'text-green-600' },
  { name: 'Powiadomienia e-mail do pacjentów', icon: 'Mail', bg: 'bg-blue-50', border: 'border-blue-100', color: 'text-blue-600' },
  { name: 'SMSy z powiadomieniami', icon: 'MessageSquare', bg: 'bg-pink-50', border: 'border-pink-100', color: 'text-pink-600' },
  { name: 'Niestandardowe typy sesji', icon: 'Settings', bg: 'bg-slate-50', border: 'border-slate-200', color: 'text-slate-600' },
  { name: 'Transkrypcje audio/video', icon: 'Mic', bg: 'bg-red-50', border: 'border-red-100', color: 'text-red-600' },
  { name: 'Zaawansowana analiza AI', icon: 'Brain', bg: 'bg-violet-50', border: 'border-violet-100', color: 'text-violet-600' },
  { name: 'Zaawansowana analityka', icon: 'ChartNoAxesCombined', bg: 'bg-cyan-50', border: 'border-cyan-100', color: 'text-cyan-600' },
  { name: 'Priorytetowe wsparcie', icon: 'Headphones', bg: 'bg-orange-50', border: 'border-orange-100', color: 'text-orange-600' },
  { name: 'Setup aplikacji przez zespół Therapy Support', icon: 'UserRoundCog', bg: 'bg-emerald-50', border: 'border-emerald-100', color: 'text-emerald-600' },
];
---

<BaseLayout
  title="Dołącz do Beta Testów — Therapy Support"
  description="Testuj Therapy Support bezpłatnie przez 5 tygodni. Platforma CBT dla terapeutów: podsumowania sesji AI, konceptualizacje, zarządzanie praktyką. Potem stała zniżka -30%."
>
  <Header />

  <main class="min-h-screen bg-slate-50">

    <!-- ===== HERO ===== -->
    <div class="bg-gradient-to-br from-brand-500 via-brand-600 to-brand-700 text-white">
      <div class="max-w-4xl mx-auto px-6 py-12 text-center">
        <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm text-white text-sm font-bold px-5 py-2 rounded-full mb-6 border border-white/20">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 0 1-1.5 1.5H5.25a1.5 1.5 0 0 1-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 1 0 9.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1 1 14.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" />
          </svg>
          Beta Testy Therapy Support
        </div>
        <h1 class="font-display text-3xl md:text-4xl font-bold mb-4">
          Dołącz do programu Beta Testów
        </h1>
        <p class="text-lg text-white/80 max-w-2xl mx-auto mb-8">
          Testuj Therapy Support bezpłatnie przez 5 tygodni. Po okresie próbnym korzystaj dalej ze stałą zniżką <span class="font-bold text-white">-30%</span> — ważną tak długo, jak utrzymujesz subskrypcję.
        </p>

        <!-- Pricing timeline -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6 max-w-xl mx-auto">
          <div class="flex items-center gap-3 bg-white/10 backdrop-blur-sm rounded-xl px-5 py-3 border border-white/15">
            <div class="w-8 h-8 rounded-full bg-accent-400/20 flex items-center justify-center border border-accent-400/30 flex-shrink-0">
              <svg class="w-4 h-4 text-accent-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 0 1-1.5 1.5H5.25a1.5 1.5 0 0 1-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 1 0 9.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1 1 14.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" />
              </svg>
            </div>
            <div class="text-left">
              <p class="text-xs text-white/60 font-medium">Pierwsze 5 tygodni</p>
              <p class="text-lg font-bold text-white">Bezpłatnie</p>
            </div>
          </div>
          <svg class="w-5 h-5 text-white/40 hidden sm:block flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
          <div class="flex items-center gap-3 bg-white/10 backdrop-blur-sm rounded-xl px-5 py-3 border border-white/15">
            <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0" style="background:rgba(167,139,250,0.25);border:1px solid rgba(167,139,250,0.4)">
              <svg class="w-4 h-4" style="color:#c4b5fd" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
              </svg>
            </div>
            <div class="text-left">
              <p class="text-xs text-white/60 font-medium">Potem na zawsze</p>
              <p class="text-lg font-bold text-white">Ze zniżką -30%</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ===== LOGO CAROUSEL ===== -->
    <div class="py-10 bg-slate-50">
      <p class="text-center text-slate-400 text-sm font-medium uppercase tracking-wider mb-8">
        Zaufali nam terapeuci z całej Polski
      </p>
      <div class="relative overflow-hidden py-6 bg-white">
        <div class="absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-slate-50 via-slate-50/80 to-transparent z-10 pointer-events-none"></div>
        <div class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-slate-50 via-slate-50/80 to-transparent z-10 pointer-events-none"></div>
        <div class="flex animate-scroll gap-6 px-6">
          {[...clinicLogos, ...clinicLogos].map((clinic, i) => (
            <div class="flex-shrink-0 flex items-center justify-center w-40 h-20 bg-white rounded-xl p-4">
              <img
                src={clinic.logo}
                alt={clinic.name}
                class="max-w-full max-h-full object-contain"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="max-w-5xl mx-auto py-10 px-6">

      <!-- ===== CO ZYSKUJESZ ===== -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 text-center mb-8">Co zyskujesz jako beta tester?</h2>

        <div class="grid md:grid-cols-2 gap-6 mb-6">

          <!-- W ramach testów sprawdzisz -->
          <div class="bg-white rounded-2xl border border-slate-200 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
              <div class="w-8 h-8 rounded-lg bg-brand-50 flex items-center justify-center border border-brand-100 flex-shrink-0" style="background:rgba(59,213,174,0.08);border-color:rgba(59,213,174,0.2)">
                <svg class="w-4 h-4 text-brand-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z" />
                </svg>
              </div>
              W ramach testów sprawdzisz
            </h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-sm text-slate-700">
                <svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                <span>Jak analiza procesu i syntetyczne podsumowania po sesjach porządkują materiał kliniczny i wspierają planowanie dalszej pracy</span>
              </li>
              <li class="flex items-start gap-3 text-sm text-slate-700">
                <svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                <span>W jaki sposób stała obecność celów terapii wpływa na spójność interwencji i poczucie kierunku procesu</span>
              </li>
              <li class="flex items-start gap-3 text-sm text-slate-700">
                <svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                <span>Jak rozwiązania organizacyjne (przedpłaty, kalendarz, notatki z sesji) ograniczają obciążenie zadaniami organizacyjnymi</span>
              </li>
            </ul>
          </div>

          <!-- Co oferujemy -->
          <div class="bg-white rounded-2xl border border-slate-200 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
              <div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center border border-emerald-100 flex-shrink-0">
                <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                </svg>
              </div>
              Co oferujemy w ramach beta testów
            </h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-sm text-slate-700">
                <svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                <span><strong>5 tygodni</strong> bezpłatnego korzystania z aplikacji, bez ograniczeń liczby pacjentów</span>
              </li>
              <li class="flex items-start gap-3 text-sm text-slate-700">
                <svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                <span>Wsparcie naszego zespołu przy przenoszeniu dotychczasowych materiałów i notatek do aplikacji</span>
              </li>
              <li class="flex items-start gap-3 text-sm text-slate-700">
                <svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                <span>Bieżąca pomoc w trakcie testów, tak aby wejście w nowy sposób pracy nie wymagało dodatkowego wysiłku</span>
              </li>
            </ul>
          </div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">

          <!-- Twoja rola -->
          <div class="bg-white rounded-2xl border border-slate-200 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
              <div class="w-8 h-8 rounded-lg bg-amber-50 flex items-center justify-center border border-amber-100 flex-shrink-0">
                <svg class="w-4 h-4 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" />
                </svg>
              </div>
              Twoja rola
            </h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-sm text-slate-700">
                <svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                <span>Dzielenie się obserwacjami z codziennej pracy z aplikacją</span>
              </li>
              <li class="flex items-start gap-3 text-sm text-slate-700">
                <svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                <span>Sygnalizowanie obszarów, które warto ulepszyć lub zmienić</span>
              </li>
              <li class="flex items-start gap-3 text-sm text-slate-700">
                <svg class="w-4 h-4 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                <span>Wskazywanie rozwiązań, które realnie dobrze sprawdzają się w Twojej praktyce terapeutycznej</span>
              </li>
            </ul>
          </div>

          <!-- Dlaczego warto -->
          <div class="bg-white rounded-2xl border border-slate-200 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
              <div class="w-8 h-8 rounded-lg bg-purple-50 flex items-center justify-center border border-purple-100 flex-shrink-0">
                <svg class="w-4 h-4 text-purple-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
                </svg>
              </div>
              Dlaczego warto
            </h3>
            <p class="text-sm text-slate-700 leading-relaxed">
              Beta testy tworzą przestrzeń do rozwoju warsztatu terapeutycznego w realnej praktyce klinicznej.
