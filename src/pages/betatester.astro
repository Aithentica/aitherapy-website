<style>
  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-scroll {
    animation: scroll 25s linear infinite;
  }
  .animate-scroll:hover {
    animation-play-state: paused;
  }
</style>

<script is:inline>
  var btnM = document.getElementById('toggle-monthly');
  var btnY = document.getElementById('toggle-yearly');
  var priceEl = document.getElementById('price-display');
  var periodEl = document.getElementById('price-period');
  var savingEl = document.getElementById('yearly-saving');
  var yearlyBadge = document.getElementById('yearly-badge');
  var originalPrice = document.getElementById('original-price');
  var badge17 = document.getElementById('badge-17');

  function setMonthly() {
    btnM.className = 'px-6 py-2.5 rounded-lg text-sm font-semibold transition-all bg-brand-500 text-white shadow-sm';
    btnY.className = 'px-6 py-2.5 rounded-lg text-sm font-semibold transition-all text-slate-600 hover:text-slate-900 flex items-center gap-2';
    yearlyBadge.className = 'text-xs px-2 py-0.5 rounded-full font-bold bg-emerald-50 text-emerald-700 border border-emerald-100';
    priceEl.textContent = '279 zł';
    periodEl.textContent = '/mies.';
    originalPrice.textContent = '399 zł';
    badge17.classList.add('hidden');
    savingEl.classList.add('hidden');
  }

  function setYearly() {
    btnY.className = 'px-6 py-2.5 rounded-lg text-sm font-semibold transition-all bg-brand-500 text-white shadow-sm flex items-center gap-2';
    btnM.className = 'px-6 py-2.5 rounded-lg text-sm font-semibold transition-all text-slate-600 hover:text-slate-900';
    yearlyBadge.className = 'text-xs px-2 py-0.5 rounded-full font-bold bg-white/20 text-white';
    priceEl.textContent = '2 784 zł';
    periodEl.textContent = '/rok';
    originalPrice.textContent = '4 788 zł';
    badge17.classList.remove('hidden');
    savingEl.classList.remove('hidden');
  }

  btnM.addEventListener('click', setMonthly);
  btnY.addEventListener('click', setYearly);
</script>
