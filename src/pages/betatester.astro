<script is:inline>
  var API_BASE = 'https://app.aitherapy.support';
  var BETA_COUPON_ID = 'promo_1Sz2UvALc8BRQ1zZG52z9NDN';
  var BETA_TRIAL_DAYS = 35;
  var BETA_SUBMIT_MESSAGE = 'Dołączasz do programu Beta Testerów Therapy Support. Po 5 tygodniach bezpłatnego okresu próbnego, Twoja subskrypcja zostanie aktywowana ze stałą zniżką -30%.';
  var BETA_DISCOUNT = 0.30;

  var billingPeriod = 'monthly';
  var plans = [];

  var btnM = document.getElementById('toggle-monthly');
  var btnY = document.getElementById('toggle-yearly');
  var priceEl = document.getElementById('price-display');
  var periodEl = document.getElementById('price-period');
  var savingEl = document.getElementById('yearly-saving');
  var yearlyBadge = document.getElementById('yearly-badge');
  var originalPrice = document.getElementById('original-price');
  var badge17 = document.getElementById('badge-17');
  var submitBtn = document.getElementById('beta-submit');
  var errorEl = document.getElementById('beta-error');

  // Fallback plans in case API is unreachable (adblocker, CORS, timeout)
  var FALLBACK_PLANS = [
    { code: 'professional', billingPeriodId: 1, price: 399, stripePriceId: 'price_1SagKmALc8BRQ1zZ8syDMaJD' },
    { code: 'professional', billingPeriodId: 2, price: 3990, stripePriceId: 'price_1SagKgALc8BRQ1zZH1bFwFEW' }
  ];

  // Load plans from API
  fetch(API_BASE + '/api/stripe/plans', { credentials: 'include' })
    .then(function(r) { if (!r.ok) throw new Error(); return r.json(); })
    .then(function(data) {
      plans = data;
      updatePriceDisplay();
    })
    .catch(function() {
      plans = FALLBACK_PLANS;
      updatePriceDisplay();
    });

  function getSelectedPlan() {
    var periodId = billingPeriod === 'yearly' ? 2 : 1;
    for (var i = 0; i < plans.length; i++) {
      if (plans[i].code === 'professional' && plans[i].billingPeriodId === periodId) {
        return plans[i];
      }
    }
    return null;
  }

  function formatPrice(price) {
    return Math.round(price) + ' zł';
  }

  function updatePriceDisplay() {
    var plan = getSelectedPlan();
    if (!plan) return;

    var fullPrice = plan.price;
    var betaPrice = Math.round(fullPrice * (1 - BETA_DISCOUNT));

    if (billingPeriod === 'monthly') {
      originalPrice.textContent = formatPrice(fullPrice);
      priceEl.textContent = formatPrice(betaPrice);
      periodEl.textContent = '/mies.';
      badge17.classList.add('hidden');
      savingEl.classList.add('hidden');
    } else {
      originalPrice.textContent = formatPrice(fullPrice);
      priceEl.textContent = formatPrice(betaPrice);
      periodEl.textContent = '/rok';
      badge17.classList.remove('hidden');
      savingEl.classList.remove('hidden');
      // Calculate yearly saving vs monthly regular
      var monthlyPlan = null;
      for (var i = 0; i < plans.length; i++) {
        if (plans[i].code === 'professional' && plans[i].billingPeriodId === 1) {
          monthlyPlan = plans[i];
          break;
        }
      }
      if (monthlyPlan) {
        var yearlyRegular = monthlyPlan.price * 12;
        var saving = yearlyRegular - betaPrice;
        savingEl.textContent = 'Oszczędzasz ~' + Math.round(saving) + ' zł rocznie vs regularna cena';
      }
    }
  }

  function setMonthly() {
    billingPeriod = 'monthly';
    btnM.className = 'px-4 py-2 rounded-lg text-sm font-semibold transition-all bg-brand-500 text-white shadow-sm';
    btnY.className = 'px-4 py-2 rounded-lg text-sm font-semibold transition-all text-slate-600 hover:text-slate-900 flex items-center gap-1.5';
    yearlyBadge.className = 'text-xs px-1.5 py-0.5 rounded-full font-bold bg-emerald-50 text-emerald-700 border border-emerald-100';
    updatePriceDisplay();
  }

  function setYearly() {
    billingPeriod = 'yearly';
    btnY.className = 'px-4 py-2 rounded-lg text-sm font-semibold transition-all bg-brand-500 text-white shadow-sm flex items-center gap-1.5';
    btnM.className = 'px-4 py-2 rounded-lg text-sm font-semibold transition-all text-slate-600 hover:text-slate-900';
    yearlyBadge.className = 'text-xs px-1.5 py-0.5 rounded-full font-bold bg-white/20 text-white';
    updatePriceDisplay();
  }

  btnM.addEventListener('click', setMonthly);
  btnY.addEventListener('click', setYearly);

  function showError(msg) {
    errorEl.textContent = msg;
    errorEl.classList.remove('hidden');
  }

  function hideError() {
    errorEl.classList.add('hidden');
  }

  submitBtn.addEventListener('click', function() {
    hideError();

    var email = document.getElementById('beta-email').value.trim();
    var phone = document.getElementById('beta-phone').value.trim();
    var consent = document.getElementById('beta-consent').checked;

    if (!email) { showError('Podaj adres e-mail'); return; }
    if (!phone) { showError('Podaj numer telefonu'); return; }
    if (!consent) { showError('Musisz zaakceptować Regulamin i Politykę Prywatności'); return; }

    var plan = getSelectedPlan();
    if (!plan || !plan.stripePriceId) {
      showError('Nie udało się załadować planu. Odśwież stronę i spróbuj ponownie.');
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Przekierowuję do płatności...';

    var body = {
      priceId: plan.stripePriceId,
      email: email,
      phoneNumber: phone,
      successUrl: window.location.origin + '/betatester/?success=1',
      cancelUrl: window.location.origin + '/betatester/',
      language: 'pl',
      couponId: BETA_COUPON_ID,
      trialDays: BETA_TRIAL_DAYS,
      submitMessage: BETA_SUBMIT_MESSAGE
    };

    fetch(API_BASE + '/api/stripe/create-checkout-session', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      body: JSON.stringify(body)
    })
    .then(function(r) {
      if (!r.ok) {
        return r.json().then(function(data) {
          throw new Error(data.error || 'Nie udało się utworzyć sesji płatności');
        });
      }
      return r.json();
    })
    .then(function(data) {
      if (data.sessionUrl) {
        window.location.href = data.sessionUrl;
      } else {
        throw new Error('Nie udało się utworzyć sesji płatności.');
      }
    })
    .catch(function(err) {
      showError(err.message || 'Nie udało się utworzyć sesji płatności. Spróbuj ponownie.');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Zapisz się';
    });
  });
</script>
